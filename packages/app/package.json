{
  "name": "@telar/app",
  "version": "0.0.0",
  "private": true,
  "description": "Tejido — app de referencia construida sobre el Design System Telar.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:firebase": "vite --mode firebase",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "e2e": "start-server-and-test dev http://localhost:5173 \"cypress run --e2e\"",
    "e2e:open": "start-server-and-test dev http://localhost:5173 \"cypress open --e2e\""
  },
  "dependencies": {
    "@tanstack/vue-table": "^8.21.0",
    "@telar/ds": "workspace:*",
    "@vee-validate/zod": "^4.15.1",
    "firebase": "^11.1.0",
    "pinia": "^2.2.0",
    "reka-ui": "^2.0.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "web-vitals": "^4.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/vue": "^8.1.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "axe-core": "^4.10.0",
    "cypress": "^14.0.0",
    "cypress-axe": "^1.6.0",
    "jsdom": "^25.0.0",
    "msw": "^2.14.6",
    "start-server-and-test": "^2.0.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "vue-tsc": "^2.1.10"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
