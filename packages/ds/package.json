{
  "name": "@telar/ds",
  "version": "0.1.0",
  "description": "Telar — Design System en Vue 3 (tokens, primitives, components, patterns).",
  "type": "module",
  "license": "UNLICENSED",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/telar.css",
    "./tokens": {
      "types": "./src/tokens/generated/tokens.ts",
      "import": "./src/tokens/generated/tokens.ts"
    }
  },
  "scripts": {
    "tokens": "node build-tokens.mjs",
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "reka-ui": "^2.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.5.0",
    "@storybook/addon-essentials": "^8.5.0",
    "@storybook/vue3": "^8.5.0",
    "@storybook/vue3-vite": "^8.5.0",
    "@testing-library/user-event": "^14.5.2",
    "@testing-library/vue": "^8.1.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vitest/coverage-v8": "^2.1.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.0",
    "reka-ui": "^2.0.0",
    "storybook": "^8.5.0",
    "style-dictionary": "^4.3.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^2.1.0",
    "vitest-axe": "^0.1.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.1.10"
  },
  "dependencies": {
    "@tanstack/vue-table": "^8.21.3"
  }
}
