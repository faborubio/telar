# Dependencies
node_modules/

# Build output
dist/
packages/*/dist/

# Storybook
storybook-static/
packages/*/storybook-static/

# Generated tokens (build artifact — regenerated by `pnpm tokens`)
packages/ds/src/tokens/generated/

# Turborepo
.turbo/

# Testing
coverage/

# Cypress (artefactos de ejecución; las specs sí se versionan)
packages/app/cypress/videos/
packages/app/cypress/screenshots/
packages/app/cypress/downloads/

# Regresión visual: los baselines (__image_snapshots__) SÍ se versionan; los diffs no.
packages/ds/__image_snapshots__/__diff_output__/

# Editor / OS
.DS_Store
*.local
.vscode/*
!.vscode/extensions.json

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Firebase
functions/lib/
.firebase/
firebase-debug.log*
firestore-debug.log*
ui-debug.log*
.runtimeconfig.json
# Env de prod: lo genera el workflow de deploy desde repo vars (config pública, no secreta).
packages/app/.env.production
# Claves de service account (NUNCA al repo; la llave maestra del Admin SDK).
*-sa.json
*firebase-adminsdk*.json
**/serviceAccount*.json
