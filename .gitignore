# Dependencies
node_modules/

# Build output
dist/
packages/*/dist/

# Storybook
storybook-static/
packages/*/storybook-static/

# Generated tokens (build artifact — regenerated by `pnpm tokens`)
packages/ds/src/tokens/generated/

# Turborepo
.turbo/

# Testing
coverage/

# Cypress (artefactos de ejecución; las specs sí se versionan)
packages/app/cypress/videos/
packages/app/cypress/screenshots/
packages/app/cypress/downloads/

# Regresión visual: los baselines (__image_snapshots__) SÍ se versionan; los diffs no.
packages/ds/__image_snapshots__/__diff_output__/

# Editor / OS
.DS_Store
*.local
.vscode/*
!.vscode/extensions.json

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
